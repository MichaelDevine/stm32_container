// For devctonaiers.json format details, see https://aka.ms/devcontainer.json. 
// For config options, see the README at:
// https://github.com/devcontainers/templates/tree/main/src/ubuntu

{
	"name": "(${localWorkspaceFolderBasename})",
	"dockerComposeFile": "docker-compose.yml",
	"service": "dev",
	// This command runs on the host before the rest of the devcontainer.json is processed. 
	// It serves two purposes:
	// 1. It attaches a supported ST-Link via usbipd so that it will be available to 
	// flashing, debugging, and terminal tools inside the containter without the 
	// container having to run "privileged. The path to the USB bus the device is on 
	// is then saved to a .env file in the .devcontainer folder on the host which is then
	// picked up by Docker. 
	// 2. It accepts additional parameters that are written to the .env file created 
	// in 1. These These are specified in a comma-delimited string of name-value pairs.
	"initializeCommand" : [
		".devcontainer\\devcontainer.bat",
		"HOST_PROJECT_NAME=${localWorkspaceFolderBasename},CONTAINER_USER=vscode"
	],
	// workspaceFolder is resolved before VS Code can read container environment
	// variables, so this path must stay literal and match docker-compose.yml.
	"workspaceFolder": "/home/vscode/zephyrproject/${localWorkspaceFolderBasename}",
	"customizations": {
		"vscode": {
			// Extensions required for the Dev Container to build, flash, debug,
			// and interact with the target. User will be prompted in the alert area
			// in VS Code to confirm install. 
			"extensions": [
				"ms-vscode.cpptools", // C/C++ IntelliSense, debugging, and code browsing
				"ms-vscode.cmake-tools", // CMake integration for building
				"stmicroelectronics.stm32-vscode-extension", // Official STM32 VS Code extension
				"marus25.cortex-debug", // Debugging for ARM Cortex-M microcontrollers
				"ms-vscode.vscode-serial-monitor" // Serial terminal for COM port
			],
			"settings": {
					"terminal.integrated.shell.linux": "/bin/bash",
						"C_Cpp.default.compilerPath": "target",
						"C_Cpp.default.intelliSenseMode": "linux-gcc-arm"
				}
		}
	},
	"remoteEnv": {
		"HOST_PROJECT_NAME": "${localWorkspaceFolderBasename}"
	},

	"postStartCommand": "sudo bash \"${containerWorkspaceFolder}/.devcontainer/post-start.sh\" \"${containerWorkspaceFolder}\""

}
