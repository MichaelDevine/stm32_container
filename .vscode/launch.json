{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "STM32XXXX: Run and Debug",
            "type": "cortex-debug",
            "request": "launch",
            "servertype": "openocd",
            "device": "STM32XXXX",
            "runToEntryPoint": "main",
            "executable": "${workspaceFolder}/build/App/myproject.elf",
            "svdFile": "${workspaceFolder}/.vscode/STM32XXXX.svd",
            "cwd": "${workspaceRoot}",
            "rtos": "auto",
            "configFiles": [
                "board/STM32XXXX.cfg"
            ]
        },
        {
            "name": "STM L475E: Attach",
            "type": "cortex-debug",
            "request": "attach",
            "servertype": "openocd",
            "device": "STM32XXXX",
            "executable": "${workspaceFolder}/build/App/myproject.elf",
            "svdFile": "${workspaceFolder}/.vscode/STM32XXXX.svd",
            "cwd": "${workspaceRoot}",
            "rtos": "auto",
            "configFiles": [
                "board/STM32XXXX.cfg"
            ]
        }
    ],
    "inputs": [
        {
            "id": "device.host",
            "type": "promptString",
            "default": "localhost:3333",
            "description": "The local hostname with port for GDB to connect to"
        }
    ]
}
