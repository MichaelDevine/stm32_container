// For devctonaiers.json format details, see https://aka.ms/devcontainer.json. 
// For config options, see the README at:
// https://github.com/devcontainers/templates/tree/main/src/ubuntu

{
	"name": "(${localWorkspaceFolderBasename})",
	"dockerComposeFile": "docker-compose.yml",
	"service": "dev",
	"workspaceFolder": "/home/vscode/zephyrproject/${localWorkspaceFolderBasename}",
	"customizations": {
		"vscode": {
				// Extensions installed inside the container. This list will be reduced to
				// the minimum set needed for the Dev Container to work, and the optional ones
				// will be specified in the code-workspace file
			"extensions": [
				"ms-vscode.cpptools", // C/C++ IntelliSense, debugging, and code browsing
        "ms-vscode.cpptools-extension-pack",
				"ms-vscode.cmake-tools", // CMake integration for building
        "ms-vscode.vscode-embedded-tools",
				"stmicroelectronics.stm32-vscode-extension", // Official STM32 VS Code extension
				"marus25.cortex-debug", // Debugging for ARM Cortex-M microcontrollers
        "marus25.cortex-debug-dp-stm32l4",
				"ms-vscode.vscode-serial-monitor", // Serial terminal for COM port
        "trond-snekvik.gnu-mapfiles",
        "shd101wyy.markdown-preview-enhanced",
        "xaver.clang-format"
			],
			"settings": {
					"terminal.integrated.shell.linux": "/bin/bash",
						"C_Cpp.default.compilerPath": "target",
						"C_Cpp.default.intelliSenseMode": "linux-gcc-arm"
				}
		}
	},
	"remoteEnv": {
		"HOST_PROJECT_NAME": "${localWorkspaceFolderBasename}"
	},

	"postStartCommand": "sudo bash \"${containerWorkspaceFolder}/.devcontainer/post-start.sh\" \"${containerWorkspaceFolder}\"",

	"remoteUser": "vscode",

	// This command runs on the host before startup, attaches a supported ST-Link via
	// usbipd, accepts a comma-separated list of NAME=VALUE pairs from devcontainer.json,
	// and writes them to .devcontainer/.env for docker-compose path and USB bind-mount
	// substitution. Add more pairs by extending the string below, e.g. "a=b,c=d,e=f".
	"initializeCommand" : [
		".devcontainer\\devcontainer.bat",
		"HOST_PROJECT_NAME=${localWorkspaceFolderBasename},ABC=CDE"
	]
}
