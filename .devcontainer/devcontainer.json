// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/ubuntu
{
	"name": "STM32 Dev Container",
	"build": {
			"dockerfile": "Dockerfile"
		},
	"workspaceMount": "source=${localWorkspaceFolder},target=/home/vscode/zephyrproject/${localWorkspaceFolderBasename},type=bind",
	"workspaceFolder": "/home/vscode/zephyrproject/${localWorkspaceFolderBasename}",
	// Linux assigns a new DEVNUM when usbipd re-enumerates the ST-LINK, so do not bind a
	// single /dev/bus/usb/BBB/DDD node here. devcontainer.bat persists the discovered bus
	// mount path in USB_STLINK_BUS_DIR, and the device cgroup rule allows USB character
	// device read/write access without mknod.
	"runArgs": [
		"--device-cgroup-rule",
		"c 189:* rw",
		"--device=/dev/ttyACM0"
	],
	"customizations": {
		"vscode": {
				// Extensions installed inside the container.
			"extensions": [
				"ms-vscode.cpptools", // C/C++ IntelliSense, debugging, and code browsing
        "ms-vscode.cpptools-extension-pack",
				"ms-vscode.cmake-tools", // CMake integration for building
        "ms-vscode.vscode-embedded-tools",
				"stmicroelectronics.stm32-vscode-extension", // Official STM32 VS Code extension
				"marus25.cortex-debug", // Debugging for ARM Cortex-M microcontrollers
        "marus25.cortex-debug-dp-stm32l4",
				"ms-vscode.vscode-serial-monitor", // Serial terminal for COM port
        "trond-snekvik.gnu-mapfiles",
        "shd101wyy.markdown-preview-enhanced",
        "xaver.clang-format"
			],
			"settings": {
					"terminal.integrated.shell.linux": "/bin/bash",
						"C_Cpp.default.compilerPath": "target",
						"C_Cpp.default.intelliSenseMode": "linux-gcc-arm"
				}
		}
	},

	"mounts": [
		"source=${localEnv:USB_STLINK_BUS_DIR},target=${localEnv:USB_STLINK_BUS_DIR},type=bind"
	],
	"postStartCommand": "sudo bash \"${containerWorkspaceFolder}/.devcontainer/post-start.sh\" \"${containerWorkspaceFolder}\"",

	"remoteUser": "vscode",

	// This command runs on the host before startup and attaches a supported ST-Link to Docker Desktop via usbipd.
	"initializeCommand" : ".devcontainer\\devcontainer.bat"
}
